  <diagram name="Page-1" id="t68T_rn4zKk8usFG7Eri">
    <mxGraphModel dx="2150" dy="1500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph LR\n    %% ==========================================\n    %% تنسيق الاستايل والجداول والفونوت\n    %% ==========================================\n    classDef tableStyle fill:#ffffff,stroke:#333333,stroke-width:1px,text-align:left,font-family:Segoe UI,Helvetica,Arial,sans-serif;\n    \n    %% ==========================================\n    %% 1. طبقة المصدر (OLAP Source - 9 Tables)\n    %% ==========================================\n    subgraph OLAP_Source [OLAP]\n        style OLAP_Source fill:#f9dbdb,stroke:#ea9999,stroke-width:2px\n        \n        %% زون العملاء\n        src_cust[\&quot;&lt;b&gt;Customer_OLAP&lt;/b&gt;&lt;hr&gt;• CustomerKey&lt;br&gt;• GeographyKey&lt;br&gt;• BusinessType&lt;br&gt;• Customer&lt;br&gt;• NumberEmployees&lt;br&gt;• AnnualRevenue&lt;br&gt;• YearOpened\&quot;]:::tableStyle\n        src_geo[\&quot;&lt;b&gt;Geography_OLAP&lt;/b&gt;&lt;hr&gt;• GeographyKey&lt;br&gt;• CityName&lt;br&gt;• StateCode&lt;br&gt;• StateName&lt;br&gt;• CountryCode&lt;br&gt;• CountryName&lt;br&gt;• RegionKey\&quot;]:::tableStyle\n        src_region[\&quot;&lt;b&gt;Region_OLAP&lt;/b&gt;&lt;hr&gt;• RegionKey&lt;br&gt;• Region&lt;br&gt;• StateCode&lt;br&gt;• Country&lt;br&gt;• Continent\&quot;]:::tableStyle\n        \n        %% زون المنتجات والتكلفة\n        src_prod[\&quot;&lt;b&gt;Product_OLAP&lt;/b&gt;&lt;hr&gt;• ProductKey&lt;br&gt;• ProductSubcategoryKey&lt;br&gt;• ProductName&lt;br&gt;• Size&lt;br&gt;• Detail\&quot;]:::tableStyle\n        src_subcat[\&quot;&lt;b&gt;ProductSubcategory_OLAP&lt;/b&gt;&lt;hr&gt;• ProductSubcategoryKey&lt;br&gt;• SubcategoryName&lt;br&gt;• CategoryName\&quot;]:::tableStyle\n        src_cost_hist[\&quot;&lt;b&gt;ProductCostHistory_OLAP&lt;/b&gt;&lt;hr&gt;• Year&lt;br&gt;• MonthNo&lt;br&gt;• CountryCode&lt;br&gt;• DueDate&lt;br&gt;• ProductKey&lt;br&gt;• Unitcost\&quot;]:::tableStyle\n        \n        %% زون المبيعات والمرتجعات\n        src_sales_head[\&quot;&lt;b&gt;SalesHeader_OLAP&lt;/b&gt;&lt;hr&gt;• SalesHeaderKey&lt;br&gt;• SalesOrderNumber&lt;br&gt;• OrderDate&lt;br&gt;• DueDate&lt;br&gt;• ShipDate&lt;br&gt;• CustomerKey&lt;br&gt;• UnitPrice&lt;br&gt;• RegionKey&lt;br&gt;• DiscountAmount&lt;br&gt;• TotalAmount&lt;br&gt;• SalesAmount\&quot;]:::tableStyle\n        src_sales_det[\&quot;&lt;b&gt;SalesDetails_OLAP&lt;/b&gt;&lt;hr&gt;• SalesDetailsKey&lt;br&gt;• SalesHeaderKey&lt;br&gt;• SalesOrderNumber&lt;br&gt;• ProductKey&lt;br&gt;• ProductSubcategoryKey&lt;br&gt;• OrderQuantity&lt;br&gt;• UnitPrice&lt;br&gt;• ExtendedAmount\&quot;]:::tableStyle\n        src_ret[\&quot;&lt;b&gt;SalesReturns_OLAP&lt;/b&gt;&lt;hr&gt;• ReturnKey&lt;br&gt;• ReturnDate&lt;br&gt;• OrderDate&lt;br&gt;• SalesOrderNumber&lt;br&gt;• CustomerKey&lt;br&gt;• ProductKey&lt;br&gt;• ReturnQuantity&lt;br&gt;• UnitPrice&lt;br&gt;• ReturnAmount\&quot;]:::tableStyle\n    end\n\n    %% ==========================================\n    %% 2. طبقة الاستيدج (Staging Area - 9 Tables Raw + 4 Views)\n    %% ==========================================\n    subgraph SA_Layer [SA]\n        style SA_Layer fill:#fff2cc,stroke:#b4a7d6,stroke-width:2px\n        \n        %% الجداول الـ 9 المنقولة كـ Raw\n        sa_cust[\&quot;&lt;b&gt;Customer_SA&lt;/b&gt;&lt;hr&gt;• CustomerKey&lt;br&gt;• GeographyKey&lt;br&gt;• BusinessType&lt;br&gt;• Customer&lt;br&gt;• NumberEmployees&lt;br&gt;• AnnualRevenue&lt;br&gt;• YearOpened\&quot;]:::tableStyle\n        sa_geo[\&quot;&lt;b&gt;Geography_SA&lt;/b&gt;&lt;hr&gt;• GeographyKey&lt;br&gt;• CityName&lt;br&gt;• StateCode&lt;br&gt;• StateName&lt;br&gt;• CountryCode&lt;br&gt;• CountryName&lt;br&gt;• RegionKey\&quot;]:::tableStyle\n        sa_region[\&quot;&lt;b&gt;Region_SA&lt;/b&gt;&lt;hr&gt;• RegionKey&lt;br&gt;• Region&lt;br&gt;• StateCode&lt;br&gt;• Country&lt;br&gt;• Continent\&quot;]:::tableStyle\n        \n        sa_prod[\&quot;&lt;b&gt;Product_SA&lt;/b&gt;&lt;hr&gt;• ProductKey&lt;br&gt;• ProductSubcategoryKey&lt;br&gt;• ProductName&lt;br&gt;• Size&lt;br&gt;• Detail\&quot;]:::tableStyle\n        sa_subcat[\&quot;&lt;b&gt;ProductSubcategory_SA&lt;/b&gt;&lt;hr&gt;• ProductSubcategoryKey&lt;br&gt;• SubcategoryName&lt;br&gt;• CategoryName\&quot;]:::tableStyle\n        sa_cost_sa[\&quot;&lt;b&gt;ProductCostHistory_SA&lt;/b&gt;&lt;hr&gt;• Year&lt;br&gt;• MonthNo&lt;br&gt;• CountryCode&lt;br&gt;• DueDate&lt;br&gt;• ProductKey&lt;br&gt;• Unitcost\&quot;]:::tableStyle\n        \n        sa_sales_head[\&quot;&lt;b&gt;SalesHeader_SA&lt;/b&gt;&lt;hr&gt;• SalesHeaderKey&lt;br&gt;• SalesOrderNumber&lt;br&gt;• OrderDate&lt;br&gt;• DueDate&lt;br&gt;• ShipDate&lt;br&gt;• CustomerKey&lt;br&gt;• UnitPrice&lt;br&gt;• RegionKey&lt;br&gt;• DiscountAmount&lt;br&gt;• TotalAmount&lt;br&gt;• SalesAmount\&quot;]:::tableStyle\n        sa_sales_det[\&quot;&lt;b&gt;SalesDetails_SA&lt;/b&gt;&lt;hr&gt;• SalesDetailsKey&lt;br&gt;• SalesHeaderKey&lt;br&gt;• SalesOrderNumber&lt;br&gt;• ProductKey&lt;br&gt;• ProductSubcategoryKey&lt;br&gt;• OrderQuantity&lt;br&gt;• UnitPrice&lt;br&gt;• ExtendedAmount\&quot;]:::tableStyle\n        sa_ret[\&quot;&lt;b&gt;SalesReturns_SA&lt;/b&gt;&lt;hr&gt;• ReturnKey&lt;br&gt;• ReturnDate&lt;br&gt;• OrderDate&lt;br&gt;• SalesOrderNumber&lt;br&gt;• CustomerKey&lt;br&gt;• ProductKey&lt;br&gt;• ReturnQuantity&lt;br&gt;• UnitPrice&lt;br&gt;• ReturnAmount\&quot;]:::tableStyle\n\n        %% الفيوز الـ 4 المدمجة (Views)\n        vw_cust[\&quot;&lt;b&gt;VIEWCustomer_SA (VIEW)&lt;/b&gt;&lt;hr&gt;• CustomerKey&lt;br&gt;• Customer&lt;br&gt;• BusinessType&lt;br&gt;• CityName&lt;br&gt;• StateName&lt;br&gt;• CountryName&lt;br&gt;• Continent\&quot;]:::tableStyle\n        vw_prod[\&quot;&lt;b&gt;VIEWProduct_SA (VIEW)&lt;/b&gt;&lt;hr&gt;• ProductKey&lt;br&gt;• ProductName&lt;br&gt;• Size&lt;br&gt;• Detail&lt;br&gt;• SubcategoryName&lt;br&gt;• CategoryName\&quot;]:::tableStyle\n        vw_sales[\&quot;&lt;b&gt;VIEWSales_SA (VIEW)&lt;/b&gt;&lt;hr&gt;• OrderDate&lt;br&gt;• DueDate&lt;br&gt;• ShipDate&lt;br&gt;• SalesOrderNumber&lt;br&gt;• CustomerKey&lt;br&gt;• ProductKey&lt;br&gt;• OrderQuantity&lt;br&gt;• UnitPrice&lt;br&gt;• UnitCost&lt;br&gt;• discount_precentage&lt;br&gt;• discount_value&lt;br&gt;• net_sales\&quot;]:::tableStyle\n        vw_ret[\&quot;&lt;b&gt;VIEWReturns_SA (VIEW)&lt;/b&gt;&lt;hr&gt;• OrderDate&lt;br&gt;• ReturnDate&lt;br&gt;• SalesOrderNumber&lt;br&gt;• CustomerKey&lt;br&gt;• ProductKey&lt;br&gt;• ReturnQuantity&lt;br&gt;• UnitPrice&lt;br&gt;• ReturnAmount\&quot;]:::tableStyle\n    end\n\n    %% ==========================================\n    %% 3. طبقة المستودع النهائي (Data Warehouse - 4 Tables)\n    %% ==========================================\n    subgraph DWH_Layer [DWH]\n        style DWH_Layer fill:#d5e8d4,stroke:#b6d7a8,stroke-width:2px\n        \n        dwh_cust[\&quot;&lt;b&gt;DIMCustomer_DWH&lt;/b&gt;&lt;hr&gt;• CustomerKey&lt;br&gt;• Customer&lt;br&gt;• BusinessType&lt;br&gt;• CityName&lt;br&gt;• StateCode (NULL)&lt;br&gt;• StateName&lt;br&gt;• CountryName&lt;br&gt;• Continent\&quot;]:::tableStyle\n        dwh_prod[\&quot;&lt;b&gt;DIMProduct_DWH&lt;/b&gt;&lt;hr&gt;• ProductKey&lt;br&gt;• ProductName&lt;br&gt;• Size&lt;br&gt;• Detail&lt;br&gt;• SubcategoryName&lt;br&gt;• CategoryName\&quot;]:::tableStyle\n        dwh_sales[\&quot;&lt;b&gt;FACTSales_DWH&lt;/b&gt;&lt;hr&gt;• OrderDate&lt;br&gt;• DueDate&lt;br&gt;• ShipDate&lt;br&gt;• SalesOrderNumber&lt;br&gt;• CustomerKey&lt;br&gt;• ProductKey&lt;br&gt;• OrderQuantity&lt;br&gt;• UnitPrice&lt;br&gt;• UnitCost&lt;br&gt;• DiscountPct&lt;br&gt;• Discount&lt;br&gt;• NetSales\&quot;]:::tableStyle\n        dwh_ret[\&quot;&lt;b&gt;FACTReturns_DWH&lt;/b&gt;&lt;hr&gt;• OrderDate&lt;br&gt;• ReturnDate&lt;br&gt;• SalesOrderNumber&lt;br&gt;• CustomerKey&lt;br&gt;• ProductKey&lt;br&gt;• ReturnQuantity&lt;br&gt;• UnitPrice&lt;br&gt;• ReturnAmount\&quot;]:::tableStyle\n    end\n\n    %% ==========================================\n    %% روابط التدفق والدمج (الأسهم المنطقية)\n    %% ==========================================\n    %% 1. النقل المباشر من الـ OLAP للـ SA\n    src_cust --&gt; sa_cust\n    src_geo --&gt; sa_geo\n    src_region --&gt; sa_region\n    src_prod --&gt; sa_prod\n    src_subcat --&gt; sa_subcat\n    src_cost_hist --&gt; sa_cost_sa\n    src_sales_head --&gt; sa_sales_head\n    src_sales_det --&gt; sa_sales_det\n    src_ret --&gt; sa_ret\n\n    %% 2. الدمج والـ Mapping من جداول الـ SA إلى الفيوز (Views)\n    sa_cust --&gt;|Merge| vw_cust\n    sa_geo --&gt;|Merge| vw_cust\n    sa_region --&gt;|Merge| vw_cust\n\n    sa_prod --&gt;|Merge| vw_prod\n    sa_subcat --&gt;|Merge| vw_prod\n\n    sa_sales_head --&gt;|Merge| vw_sales\n    sa_sales_det --&gt;|Merge| vw_sales\n    sa_cost_sa --&gt;|Lookup Cost| vw_sales\n\n    sa_ret --&gt;|Merge| vw_ret\n\n    %% 3. التحميل النهائي من الفيوز للـ DWH عن طريق الـ Procedures\n    vw_cust --&gt; dwh_cust\n    vw_prod --&gt; dwh_prod\n    vw_sales --&gt; dwh_sales\n    vw_ret --&gt; dwh_ret&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="GPd7Qz5IE0MAb-N0b6t5-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;fontColor=#000000;fontSize=14;" vertex="1">
